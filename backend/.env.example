# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# Port 6543: Used by FastAPI for connection pooling during runtime execution
DATABASE_URL="postgresql://[user]:[password]@[host]:6543/[database]?sslmode=require&supa=t"

# Port 5432: Used exclusively by Alembic to prevent migration transaction locks
ALEMBIC_DATABASE_URL="postgresql://[user]:[password]@[host]:5432/[database]?sslmode=require"

# ==============================================================================
# SUPABASE EXTERNAL AUTH & API CONFIGURATION
# ==============================================================================
# Derived from your Supabase project reference ID
SUPABASE_PROJECT_URL="https://[project-id].supabase.co"

# Paste your full 'Anon public' key here
SUPABASE_ANON_KEY="your-anon-key-here"

# Standard Supabase JWT validation configurations
SUPABASE_JWT_ISSUER="https://[project-id].supabase.co/auth/v1"
SUPABASE_JWT_AUDIENCE="authenticated"

# ==============================================================================
# ROOMMATE MATCHER SAAS APPLICATION CONFIGURATION
# ==============================================================================
# SECURITY WARNING: Generate a secure 32-character hex string for application-issued demo tokens.
# You can generate one via terminal using: openssl rand -hex 32
APP_JWT_SECRET="your-generated-jwt-secret-here"

# Comma-separated list of emails allowed to access the Super-Admin / God-Mode platform console
ADMIN_EMAILS="admin1@example.com,admin2@example.com"

# Local development URL (derived from your Site URL)
FRONTEND_URL="http://localhost:5173"

# Deep link contact number for the DFY onboarding mechanism (include country code, no spaces)
WHATSAPP_DFY_NUMBER="+1234567890"

# Time-To-Live duration for temporary recruiter shadow tenant sandboxes
DEMO_TTL_HOURS=24
SUPABASE_JWT_SECRET="your-supabase-jwt-secret-here"
